# Server
PORT=5000

# Frontend URL (for CORS) - update to your frontend's origin
CLIENT_URL=http://localhost:5000

# Email (SMTP) configuration
# Example below uses Gmail. For Gmail you must use an "App Password",
# not your normal password (enable 2FA first, then generate an app password):
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender display name/email shown to recipients
EMAIL_FROM="OTP Service <your-email@gmail.com>"

# OTP settings
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
